    "/v1/{parent}/logs": {
      "get": {
        "summary": "List LLM logs",
        "operationId": "LLMProxy_ListOpenAIChatLogs",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListOpenAIChatLogsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "parent",
            "description": "The parent resource collection. In this case, \"/openai_chats/{model_name}\".",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "openaiChats/[^/]+"
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "pageToken",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filters.relativeDatetimeFilters.fromS",
            "description": "Number of seconds from current datetime",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "uint64"
          },
          {
            "name": "filters.userfeedbackFilter.thumbsReaction",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "THUMBS_UNSPECIFIED",
              "THUMBS_UP",
              "THUMBS_DOWN"
            ],
            "default": "THUMBS_UNSPECIFIED"
          },
          {
            "name": "filters.attributeFilters.keys",
            "in": "query",
            "required": false,
            "type": "array",
            "items": {
              "type": "string"
            },
            "collectionFormat": "multi"
          },
          {
            "name": "filters.attributeFilters.values",
            "in": "query",
            "required": false,
            "type": "array",
            "items": {
              "type": "string"
            },
            "collectionFormat": "multi"
          },
          {
            "name": "filters.datasetFilters.datasetNames",
            "in": "query",
            "required": false,
            "type": "array",
            "items": {
              "type": "string"
            },
            "collectionFormat": "multi"
          },
          {
            "name": "mode",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "MODE_UNSPECIFIED",
              "MODE_TEST",
              "MODE_STAGING",
              "MODE_PROD"
            ],
            "default": "MODE_UNSPECIFIED"
          },
          {
            "name": "countEntries",
            "description": "Whether to also return a count of all the entries matching the list query.",
            "in": "query",
            "required": false,
            "type": "boolean"
          }
        ],
        "tags": [
          "LLMProxy"
        ]
      }
    }
  },
  "definitions": {
    "AppLogLevelType": {
      "type": "string",
      "enum": [
        "TRACE",
        "DEBUG",
        "INFO",
        "WARN",
        "ERROR",
        "FATAL"
      ],
      "default": "TRACE"
    },
    "OpenAIChatOutputLogChoice": {
      "type": "object",
      "properties": {
        "index": {
          "type": "string"
        },
        "message": {
          "$ref": "#/definitions/v1Message"
        },
        "finishReason": {
          "type": "string"
        }
      }
    },
    "OpenAIChatOutputLogUsage": {
      "type": "object",
      "properties": {
        "promptTokens": {
          "type": "integer",
          "format": "int64"
        },
        "completionTokens": {
          "type": "integer",
          "format": "int64"
        },
        "totalTokens": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "protobufNullValue": {
      "type": "string",
      "enum": [
        "NULL_VALUE"
      ],
      "default": "NULL_VALUE",
      "description": "`NullValue` is a singleton enumeration to represent the null value for the\n`Value` type union.\n\nThe JSON representation for `NullValue` is JSON `null`.\n\n - NULL_VALUE: Null value."
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1ApiSecret": {
      "type": "object",
      "properties": {
        "alias": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "provider": {
          "$ref": "#/definitions/v1ApiSecretProvider"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "secret": {
          "type": "string"
        }
      }
    },
    "v1ApiSecretProvider": {
      "type": "string",
      "enum": [
        "API_SECRET_PROVIDER_UNSPECIFIED",
        "API_SECRET_PROVIDER_OPENAI"
      ],
      "default": "API_SECRET_PROVIDER_UNSPECIFIED"
    },
    "v1AppLog": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "title": "Id of the log"
        },
        "traceId": {
          "type": "string"
        },
        "level": {
          "$ref": "#/definitions/AppLogLevelType"
        },
        "message": {
          "type": "string"
        },
        "additionalInfo": {
          "type": "object"
        },
        "eventTimestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "v1AttributeFilters": {
      "type": "object",
      "properties": {
        "keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "v1CreateApiSecretRequest": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/definitions/v1ApiSecretProvider"
        },
        "secret": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "v1CreateAppLogsRequest": {
      "type": "object",
      "properties": {
        "appLogs": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1AppLog"
          }
