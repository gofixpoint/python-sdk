      "post": {
        "summary": "Create LLM routing config",
        "description": "Creates an LLM inference routing config so you can dynamically control to\nwhich LLM models or inference providers Fixpoint sends LLM inference\nrequests.\n\nRouting configs can:\n\n- Have configurable spending caps per model",
        "operationId": "LLMProxy_CreateRoutingConfig",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1RoutingConfig"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1CreateRoutingConfigRequest"
            }
          }
        ],
        "tags": [
          "LLMProxy"
        ]
      }
    },
    "/v1/routing_configs/{routeConfigId}": {
      "patch": {
        "summary": "Update routing config spending totals",
        "description": "Update spending totals on a routing config.",
        "operationId": "LLMProxy_UpdateSpendingTotals",
        "responses": {
          "200": {
            "description": "A successful response.",
