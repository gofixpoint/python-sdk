            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "models": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "$ref": "#/definitions/v1Model"
                  },
                  "title": "Spend cap and totals for each model are deltas so that the client cannot alter usage metrics"
                }
              }
            }
          }
        ],
        "tags": [
          "LLMProxy"
        ]
      }
