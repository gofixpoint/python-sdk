            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "sessionName": {
                  "type": "string"
                },
                "messages": {
                  "type": "array",
                  "items": {
                    "type": "object",
